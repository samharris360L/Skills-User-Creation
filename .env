# =============================================================================
# Secrets — copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit real credentials.
# =============================================================================

# 360Learning API credentials (Client Credentials OAuth 2.0)
# Create these in the API v2 admin panel of your 360Learning instance.
THREESIXTY_CLIENT_ID=decd8692833b4bb8a08b7f0f873fe4fd
THREESIXTY_CLIENT_SECRET=6f6db60e937444b89e7f1cc0ed9ad549

# Optional: override if you're on a non-default region.
THREESIXTY_BASE_URL=https://app.360learning.com/api/v2

# Group _id per language. Find them via GET /api/v2/groups.
ENGLISH_GROUP_ID=67225cbac852c0c4f2380221
FRENCH_GROUP_ID=67225cc4a93defd35c79ece6
GERMAN_GROUP_ID=67225cce2035e1084d6ba622

# Days until the created user is auto-deactivated by 360Learning.
EXPIRY_DAYS=3

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
